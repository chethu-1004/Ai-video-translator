PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here_change_in_production
MAX_FILE_SIZE=104857600
ALLOWED_VIDEO_FORMATS=mp4,mkv,mov,avi,webm
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
LOG_DIR=./logs

# ===========================================
# SARVAM AI API CONFIGURATION (REQUIRED)
# ===========================================
# Sarvam AI provides hosted APIs for Indian languages
# Get your free API key at: https://dashboard.sarvam.ai/
# 
# Supported Languages (22 Indian languages):
# Hindi (hi-IN), Kannada (kn-IN), Telugu (te-IN), Tamil (ta-IN), 
# Malayalam (ml-IN), Bengali (bn-IN), Gujarati (gu-IN), Marathi (mr-IN),
# Odia (od-IN), Punjabi (pa-IN), Assamese (as-IN), and more...

SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_URL=https://api.sarvam.ai

# Processing Configuration
MAX_CONCURRENT_JOBS=2
CHUNK_DURATION_SECONDS=30
